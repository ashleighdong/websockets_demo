# Leave unset for local dev: Vite proxies /api and /ws to the backend (see vite.config.js).
# For production builds (e.g. static site calling your Render API), set the public API origin, no trailing slash:
# VITE_API_BASE_URL=https://your-api.onrender.com

# Optional: backend URL for the dev proxy if not running the API on port 3000
# VITE_PROXY_TARGET=http://127.0.0.1:3000
