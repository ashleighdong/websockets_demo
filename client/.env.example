# Local dev with Vite: leave VITE_API_BASE_URL unset so /api and /ws are proxied to the backend.
# Production (React built to client/dist and served by Express): also leave unset — same origin.

# Only needed if the built JS is hosted on a different origin than the API:
# VITE_API_BASE_URL=https://your-api.example.com

# Optional: backend URL for the Vite dev proxy (default http://127.0.0.1:3000)
# VITE_PROXY_TARGET=http://127.0.0.1:3000
